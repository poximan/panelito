<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_telefono_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/txt_telefono_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/telefono_number_text"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txt_telefono_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/telefono_comment_text"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txt_telefono_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/telefono_hint_text"
        android:textSize="12sp" />

</LinearLayout>
